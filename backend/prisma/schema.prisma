// This is your Prisma schema file
// Online Usta Platform - Database Schema v1.0

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
    USER
    MASTER
    ADMIN
}

enum UserStatus {
    ACTIVE
    BLOCKED
    PENDING
}

enum OrderStatus {
    PENDING // Kutilmoqda
    ACCEPTED // Usta qabul qildi
    CONTRACT_SENT // Shartnoma yuborildi
    PAYMENT_PENDING // To'lov kutilmoqda
    PAYMENT_DONE // To'lov amalga oshdi
    IN_PROGRESS // Bajarilmoqda
    COMPLETED // Tugallandi
    CANCELLED // Bekor qilindi
}

enum PaymentType {
    PAYME
    CLICK
    CASH
}

enum PaymentStatus {
    PENDING
    COMPLETED
    FAILED
    REFUNDED
}

enum SubscriptionType {
    DAILY // Kunlik
    WEEKLY // Haftalik
    MONTHLY // Oylik
    COMMISSION // Foiz tizimi (12%)
}

enum SubscriptionStatus {
    ACTIVE
    EXPIRED
    CANCELLED
}

enum NotificationType {
    ORDER_CREATED
    ORDER_ACCEPTED
    CONTRACT_SENT
    PAYMENT_RECEIVED
    WORK_STARTED
    WORK_COMPLETED
    ORDER_CANCELLED
    PENALTY_ISSUED
    ACCOUNT_BLOCKED
    SYSTEM_MESSAGE
    ROLE_CHANGED
}

enum ComplaintStatus {
    PENDING
    IN_REVIEW
    RESOLVED
    REJECTED
}

enum DeviceChangeStatus {
    PENDING
    APPROVED
    REJECTED
}

// ============ MODELS ============

model User {
    id          String     @id @default(uuid())
    name        String
    phone       String     @unique
    location    String?
    latitude    Float?
    longitude   Float?
    birthYear   Int?
    role        UserRole   @default(USER)
    status      UserStatus @default(ACTIVE)
    avatar      String?
    deviceId    String?
    fcmToken    String? // Firebase Cloud Messaging token
    telegramChatId String? // Telegram bot chat ID
    lastLoginAt DateTime?
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt

    // Relations
    master            Master?
    ordersAsUser      Order[]        @relation("UserOrders")
    ordersAsMaster    Order[]        @relation("MasterOrders")
    reviews           Review[]
    complaintsFrom    Complaint[]    @relation("ComplaintsFrom")
    complaintsAgainst Complaint[]    @relation("ComplaintsAgainst")
    notifications     Notification[]

    @@map("users")
}

model Master {
    id               String           @id @default(uuid())
    userId           String           @unique
    categoryId       String?
    bio              String?
    services         String[]         @default([]) // Xizmat turlari ro'yxati
    rating           Float            @default(0)
    totalReviews     Int              @default(0)
    totalOrders      Int              @default(0)
    deviceId         String?
    subscriptionType SubscriptionType @default(COMMISSION)
    isVerified       Boolean          @default(false)
    isOnline         Boolean          @default(false)

    // Passport data (encrypted)
    passportSeries    String?
    passportNumber    String?
    passportJSHIR     String?
    passportPhoto     String? // Front photo URL
    passportPhotoBack String? // Back photo URL

    // Bank data
    bankCardNumber String?
    bankCardHolder String?

    // Statistics
    totalEarnings         Float     @default(0)
    monthlyEarnings       Float     @default(0)
    cancellationCount     Int       @default(0)
    weeklyCancellations   Int       @default(0)
    monthlyCancellations  Int       @default(0)
    lastCancellationReset DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
    category             Category?             @relation(fields: [categoryId], references: [id])
    subscriptions        Subscription[]
    geoLogs              GeoLog[]
    cancellations        Cancellation[]
    reviews              Review[]
    deviceChangeRequests DeviceChangeRequest[]

    @@map("masters")
}

model Category {
    id          String   @id @default(uuid())
    name        String
    nameUz      String
    nameRu      String?
    description String?
    icon        String?
    parentId    String?
    isActive    Boolean  @default(true)
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children Category[] @relation("CategoryHierarchy")
    masters  Master[]
    orders   Order[]

    @@map("categories")
}

model Order {
    id         String  @id @default(uuid())
    userId     String
    masterId   String?
    categoryId String?

    description  String
    address      String
    contactPhone String?
    latitude     Float?
    longitude    Float?

    preferredDate DateTime?
    preferredTime String?

    images String[] @default([])

    status       OrderStatus @default(PENDING)
    amount       Float?
    platformFee  Float?
    masterAmount Float?

    paymentType         PaymentType?
    contractSentAt      DateTime?
    contractDescription String? // Usta tomondan ish tavsifi
    acceptedAt          DateTime?
    startedAt           DateTime?
    completedAt         DateTime?
    cancelledAt         DateTime?
    cancellationReason  String?

    isFreelance Boolean @default(false) // Erkin (kategoriyasiz) buyurtma
    region      String? // Viloyat/shahar nomi (masalan: "Andijon", "Toshkent")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user         User          @relation("UserOrders", fields: [userId], references: [id])
    master       User?         @relation("MasterOrders", fields: [masterId], references: [id])
    category     Category?     @relation(fields: [categoryId], references: [id])
    payments     Payment[]
    review       Review?
    complaints   Complaint[]
    cancellation Cancellation?

    @@map("orders")
}

model Payment {
    id            String        @id @default(uuid())
    orderId       String
    amount        Float
    type          PaymentType
    status        PaymentStatus @default(PENDING)
    transactionId String?       @unique

    // Payment gateway response
    gatewayResponse Json?

    paidAt    DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    // Relations
    order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@map("payments")
}

model Subscription {
    id        String             @id @default(uuid())
    masterId  String
    tariffId  String? // Admin belgilagan tarif ID
    type      SubscriptionType
    price     Float
    startDate DateTime
    endDate   DateTime
    status    SubscriptionStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

    @@map("subscriptions")
}

model Review {
    id       String  @id @default(uuid())
    orderId  String  @unique
    userId   String
    masterId String
    rating   Int // 1-5
    comment  String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
    user   User   @relation(fields: [userId], references: [id])
    master Master @relation(fields: [masterId], references: [id])

    @@map("reviews")
}

model Complaint {
    id            String  @id @default(uuid())
    fromUserId    String
    againstUserId String
    orderId       String?

    description String
    status      ComplaintStatus @default(PENDING)
    adminNote   String?
    resolvedAt  DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    fromUser    User   @relation("ComplaintsFrom", fields: [fromUserId], references: [id])
    againstUser User   @relation("ComplaintsAgainst", fields: [againstUserId], references: [id])
    order       Order? @relation(fields: [orderId], references: [id])

    @@map("complaints")
}

model Notification {
    id     String           @id @default(uuid())
    userId String
    title  String
    body   String
    type   NotificationType
    isRead Boolean          @default(false)

    data Json?

    createdAt DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("notifications")
}

model GeoLog {
    id        String   @id @default(uuid())
    masterId  String
    latitude  Float
    longitude Float
    timestamp DateTime @default(now())

    // Relations
    master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

    @@index([masterId, timestamp])
    @@map("geo_logs")
}

model Cancellation {
    id          String   @id @default(uuid())
    orderId     String   @unique
    masterId    String
    reason      String?
    cancelledBy String // userId who cancelled
    cancelledAt DateTime @default(now())

    // Relations
    order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
    master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

    @@map("cancellations")
}

model Tariff {
    id          String           @id @default(uuid())
    name        String // e.g. "Kunlik tarif", "Haftalik tarif"
    type        SubscriptionType
    price       Float // Narxi (so'm)
    duration    Int // Davomiyligi (kunlarda): DAILY=1, WEEKLY=7, MONTHLY=30
    description String?
    isActive    Boolean          @default(true)
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt

    @@map("tariffs")
}

model PlatformSettings {
    id          String   @id @default(uuid())
    key         String   @unique
    value       String
    description String?
    updatedAt   DateTime @updatedAt

    @@map("platform_settings")
}

model OtpCode {
    id           String    @id @default(uuid())
    phone        String
    code         String
    attempts     Int       @default(0)
    isUsed       Boolean   @default(false)
    isBlocked    Boolean   @default(false)
    expiresAt    DateTime
    blockedUntil DateTime?
    createdAt    DateTime  @default(now())

    @@index([phone, createdAt])
    @@map("otp_codes")
}

model DeviceChangeRequest {
    id          String             @id @default(uuid())
    masterId    String
    oldDeviceId String?
    newDeviceId String
    status      DeviceChangeStatus @default(PENDING)
    adminNote   String?
    resolvedAt  DateTime?
    createdAt   DateTime           @default(now())
    updatedAt   DateTime           @updatedAt

    // Relations
    master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

    @@map("device_change_requests")
}
