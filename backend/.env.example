# Database
DATABASE_URL="postgresql://user:password@localhost:5432/online_usta?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# SMS Service (Eskiz / Play Mobile)
SMS_PROVIDER=eskiz
SMS_API_URL=https://notify.eskiz.uz/api
SMS_EMAIL=your-email@example.com
SMS_PASSWORD=your-sms-password
SMS_TOKEN=

# Payment Gateways
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_SERVICE_ID=your-click-service-id

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=online-usta-bucket
AWS_REGION=us-east-1
AWS_ENDPOINT=https://s3.amazonaws.com

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Application
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Admin
ADMIN_PHONE=+998901234567
ADMIN_PLATFORM_COMMISSION=12

# OTP Settings
OTP_EXPIRATION_MINUTES=3
OTP_MAX_ATTEMPTS=3
OTP_BLOCK_DURATION_MINUTES=15
